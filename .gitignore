# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
.Python
build/
dist/
wheels/
*.egg-info/
*.egg
.eggs/

# Downloaded audio (default output dir)
downloads/

# Ad-hoc local smoke-test output dirs (manual `crate` runs). These hold REAL downloaded
# audio and must NEVER be committed/pushed to a public repo (copyright). Keep this list broad:
# the *_test/ glob catches any future smoke dir (use `git add -f` if you ever need a real one).
t2/
album_test/
exe_test/
*_test/

# Safety net: never commit downloaded audio or yt-dlp download intermediates, wherever they land
# (this is a Python project; the tests use plain-text stand-ins, so no real audio lives in-tree).
*.mp3
*.m4a
*.aac
*.flac
*.opus
*.ogg
*.wav
*.webm
*.part

# Virtual environments
.venv/
venv/
env/
ENV/

# Test / coverage / type-check caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.cache/

# Secrets & local config — never commit real credentials
.env
*.env
!.env.example

# Claude Code local working notes / harness settings (not shared)
CLAUDE.local.md
.claude/

# PyInstaller — the hand-written cratedig.spec IS tracked (it is the build config); only the
# build OUTPUT is ignored. The onedir build lands in dist/ and build/ (already ignored above);
# *.exe is a release artifact and must never be committed.
*.exe

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
